{
    "name": "flutter-widget-wallet-mcp",
    "version": "2.1.0",
    "description": "Flutter widget wallet MCP — widget discovery, metadata extraction, and design-system guidance for Wi Wallet",
    "type": "module",
    "scripts": {
        "start": "node index.js",
        "start:http": "node http-server.js",
        "start:edge": "node edge-proxy.js",
        "start:dev-edge-proxy": "node scripts/dev-edge-proxy.js",
        "install-mcp": "node install.js",
        "check:mcp-syntax": "node scripts/check-syntax.js",
        "verify:mcp": "node scripts/verify-mcp.js",
        "verify:mcp:http": "node scripts/verify-http.js",
        "verify:mcp:remote": "node scripts/verify-remote.js",
        "evaluate:mcp": "node scripts/run-evaluations.js",
        "validate:onboarding": "node scripts/validate-onboarding.js",
        "ci:mcp": "node scripts/run-ci.js",
        "test": "node --test",
        "test:update-snapshots": "UPDATE_SNAPSHOTS=1 node --test"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@modelcontextprotocol/inspector": "^0.22.0"
    }
}
